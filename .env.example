# URL of the X list to fetch (must include /lists/<id>)
X_LIST_URL="https://x.com/i/lists/YOUR_LIST_ID"
# X account username used to access the list timeline
X_USERNAME="your_username"
# X cookie string for authenticated requests (cookie-only account)
# Use single quotes to avoid parsing issues with special characters
X_COOKIE='auth_token=...; ct0=...;'
# S3 bucket where the RSS XML will be uploaded
S3_BUCKET="your-bucket-name"
# S3 object key (path + file name) for the uploaded feed
S3_KEY="feeds/twilist-rss.xml"

# Optional: RSS channel title
# FEED_TITLE="X List Feed"
# Optional: RSS channel description
# FEED_DESCRIPTION="X list timeline feed"
# Optional: max number of normal posts kept in the feed
# MAX_ITEMS=50
# Optional: fetch multiplier before filtering (max_items * fetch_mult)
# FETCH_MULT=5
# Optional: local path to twscrape SQLite DB
# TWS_DB_PATH=".data/twscrape.db"
# Optional: AWS region used by boto3
# AWS_REGION="us-east-1"
# Optional: AWS CLI profile name used by boto3
# AWS_PROFILE="default"
